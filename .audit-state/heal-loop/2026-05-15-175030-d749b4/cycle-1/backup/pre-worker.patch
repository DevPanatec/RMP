+// ---------- setPlanFechas ----------
+export const setPlanFechas = mutation({
+  args: {
+    id: v.id("organizaciones"),
+    fecha_inicio_plan: v.optional(v.number()),
+    fecha_renovacion_plan: v.optional(v.number()),
+    notas: v.optional(v.string()),
+  },
+  handler: async (ctx, args) => {
